.home-page {
  display: flex;
  flex-direction: column;
}

.club-home {
  background: #ffffff;
  padding: 32rpx 38rpx 128rpx;
}

.club-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: 112rpx;
}

.club-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  background: #3f3f3f;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
  font-family: "STKaiti", "KaiTi", serif;
  box-shadow: inset -8rpx -10rpx 0 rgba(0, 0, 0, 0.16);
}

.club-actions {
  display: flex;
  align-items: center;
  gap: 30rpx;
  padding-top: 8rpx;
}

.club-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #f35f8e;
  color: #354052;
  font-size: 31rpx;
  font-weight: 800;
  box-shadow: 0 0 0 4rpx rgba(15, 23, 42, 0.08);
}

.club-bell {
  position: relative;
  width: 48rpx;
  height: 54rpx;
  border: 6rpx solid #0f172a;
  border-bottom-width: 8rpx;
  border-radius: 26rpx 26rpx 18rpx 18rpx;
  box-sizing: border-box;
}

.club-bell::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -18rpx;
  width: 18rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #0f172a;
  transform: translateX(-50%);
}

.club-hero {
  position: relative;
  padding: 92rpx 8rpx 78rpx;
}

.club-orbit {
  width: 74rpx;
  height: 54rpx;
  margin-bottom: 78rpx;
  border: 14rpx solid #c8444a;
  border-radius: 50%;
  transform: rotate(2deg);
}

.club-title {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  color: #020617;
  font-size: 72rpx;
  font-weight: 500;
  line-height: 1.2;
  letter-spacing: 4rpx;
  font-family: "STKaiti", "KaiTi", "Songti SC", serif;
}

.club-title-en {
  position: absolute;
  left: 318rpx;
  top: 280rpx;
  width: 150rpx;
  font-size: 20rpx;
  line-height: 1.12;
  letter-spacing: 0;
  font-family: Georgia, "Times New Roman", serif;
}

.club-slogan {
  margin-top: 66rpx;
  color: #1f2937;
  font-size: 34rpx;
  line-height: 1.7;
  font-family: "Songti SC", "STSong", serif;
}

.club-entry-grid {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 26rpx;
}

.club-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  width: 20%;
}

.entry-icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
}

.entry-book {
  border-radius: 10rpx;
  background: linear-gradient(180deg, #050505 0%, #050505 74%, #b8b8b8 74%, #b8b8b8 100%);
}

.entry-book::after {
  content: "";
  position: absolute;
  top: 12rpx;
  right: 14rpx;
  width: 14rpx;
  height: 24rpx;
  border-radius: 3rpx;
  background: #ffffff;
}

.entry-search {
  border-radius: 50%;
  background: #050505;
}

.entry-search::before {
  content: "";
  position: absolute;
  top: 16rpx;
  left: 22rpx;
  width: 28rpx;
  height: 16rpx;
  border-top: 7rpx solid #ffffff;
  border-radius: 50%;
  transform: rotate(18deg);
}

.entry-search::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -5rpx;
  width: 28rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #a8a8a8;
  transform: rotate(45deg);
}

.entry-camera {
  margin-top: 10rpx;
  width: 78rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #050505;
}

.entry-camera::before {
  content: "";
  position: absolute;
  top: -12rpx;
  left: 28rpx;
  width: 32rpx;
  height: 18rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #bcbcbc;
}

.entry-camera::after {
  content: "";
  position: absolute;
  top: 14rpx;
  left: 22rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #ffffff;
}

.entry-smile {
  border-radius: 50%;
  background: #050505;
  box-shadow: 0 13rpx 0 #b5b5b5;
}

.entry-smile::before {
  content: "";
  position: absolute;
  top: 20rpx;
  left: 18rpx;
  width: 7rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 29rpx 0 0 #ffffff;
}

.entry-smile::after {
  content: "";
  position: absolute;
  left: 22rpx;
  bottom: 18rpx;
  width: 30rpx;
  height: 15rpx;
  border-radius: 0 0 30rpx 30rpx;
  background: #ffffff;
}

.entry-box {
  margin-top: 16rpx;
  height: 54rpx;
  border-radius: 8rpx 8rpx 12rpx 12rpx;
  background: #050505;
}

.entry-box::before {
  content: "";
  position: absolute;
  top: -20rpx;
  left: 8rpx;
  width: 56rpx;
  height: 22rpx;
  border-radius: 8rpx;
  background: #bcbcbc;
}

.entry-text {
  white-space: nowrap;
  color: #8b8f98;
  font-size: 25rpx;
  font-weight: 700;
}

.club-entry.is-active .entry-icon {
  transform: translateY(-4rpx);
}

.club-entry.is-active .entry-text {
  color: #111827;
}

.xhs-shelf {
  margin-top: 54rpx;
  padding: 28rpx 0 10rpx;
  animation: xhsShelfIn 360ms ease both;
}

.xhs-book-stage {
  position: relative;
  height: 246rpx;
  perspective: 1000rpx;
}

.xhs-book-shadow {
  position: absolute;
  left: 90rpx;
  right: 90rpx;
  bottom: 16rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.16);
  transform: scaleX(0.78);
  animation: xhsShadowOpen 760ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.xhs-book {
  position: absolute;
  left: 50%;
  top: 18rpx;
  display: flex;
  width: 560rpx;
  height: 186rpx;
  border-radius: 28rpx;
  transform: translateX(-50%);
  transform-style: preserve-3d;
}

.xhs-book-page {
  position: relative;
  z-index: 2;
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
  padding: 30rpx;
  box-sizing: border-box;
  color: #111827;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
  background:
    radial-gradient(circle at 26% 28%, rgba(255, 255, 255, 0.8), transparent 30%),
    linear-gradient(135deg, #fff4ea 0%, #fffdf9 52%, #f8d9c0 100%);
  box-shadow: 0 22rpx 54rpx rgba(15, 23, 42, 0.16);
  backface-visibility: hidden;
}

.xhs-book-left {
  align-items: flex-end;
  border-radius: 30rpx 8rpx 8rpx 30rpx;
  transform-origin: right center;
  animation: xhsBookLeft 760ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.xhs-book-right {
  align-items: flex-start;
  border-radius: 8rpx 30rpx 30rpx 8rpx;
  transform-origin: left center;
  animation: xhsBookRight 760ms cubic-bezier(0.2, 0.75, 0.2, 1) both;
}

.xhs-book-spine {
  position: absolute;
  left: 50%;
  top: 0;
  z-index: 3;
  width: 12rpx;
  height: 186rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #1f2937 0%, #0f172a 100%);
  transform: translateX(-50%);
  box-shadow: 0 0 0 8rpx rgba(255, 255, 255, 0.78);
}

.xhs-shelf.is-open .xhs-book-left,
.xhs-shelf.is-open .xhs-book-right,
.xhs-shelf.is-open .xhs-book-shadow {
  animation: none;
}

.xhs-shelf.is-open .xhs-book-left {
  transform: rotateY(0deg) translateX(-8rpx);
}

.xhs-shelf.is-open .xhs-book-right {
  transform: rotateY(0deg) translateX(8rpx);
}

.xhs-waterfall-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 0 2rpx;
}

.xhs-kicker {
  color: #e35b5f;
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.xhs-title {
  margin-top: 8rpx;
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.xhs-count {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
}

.xhs-waterfall {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  margin-top: 28rpx;
}

.xhs-column {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 22rpx;
}

.xhs-column-right {
  padding-top: 42rpx;
}

.xhs-card {
  overflow: hidden;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 46rpx rgba(15, 23, 42, 0.08);
  animation: xhsCardIn 520ms ease both;
}

.xhs-card-cover {
  display: block;
  width: 100%;
  height: 408rpx;
  background: #f4f4f5;
}

.xhs-card-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  box-sizing: border-box;
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.35;
}

.xhs-card-body {
  padding: 18rpx 18rpx 22rpx;
}

.xhs-card-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 1.45;
}

.xhs-card-desc {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.xhs-empty {
  margin-top: 26rpx;
  padding: 30rpx;
  border-radius: 26rpx;
  background: #f7f2ed;
  color: #6b7280;
  font-size: 24rpx;
  text-align: center;
}

.club-section {
  margin-top: 92rpx;
}

.club-section-title {
  color: #111827;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.club-section-subtitle {
  margin-top: 12rpx;
  color: #8b8f98;
  font-size: 24rpx;
}

.club-card-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  row-gap: 22rpx;
  margin-top: 36rpx;
}

.club-card {
  overflow: hidden;
  width: 48.3%;
  border-radius: 34rpx 34rpx 18rpx 18rpx;
  background: #f6f6f6;
}

.club-cover-wrap {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 420rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #f4f4f4;
}

.club-cover {
  width: 100%;
  height: 100%;
}

.club-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 34rpx;
  box-sizing: border-box;
  color: #111827;
  font-size: 34rpx;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.4;
}

.club-new {
  position: absolute;
  top: 16rpx;
  right: 14rpx;
  padding: 10rpx 22rpx;
  border-radius: 18rpx;
  background: #e9693c;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.club-card-body {
  padding: 20rpx 18rpx 24rpx;
}

.club-card-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.45;
}

.club-card-desc {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.6;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

@keyframes xhsShelfIn {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes xhsBookLeft {
  from {
    transform: rotateY(-70deg) translateX(90rpx) scale(0.92);
  }
  to {
    transform: rotateY(0deg) translateX(-8rpx) scale(1);
  }
}

@keyframes xhsBookRight {
  from {
    transform: rotateY(70deg) translateX(-90rpx) scale(0.92);
  }
  to {
    transform: rotateY(0deg) translateX(8rpx) scale(1);
  }
}

@keyframes xhsShadowOpen {
  from {
    opacity: 0.18;
    transform: scaleX(0.3);
  }
  to {
    opacity: 1;
    transform: scaleX(0.78);
  }
}

@keyframes xhsCardIn {
  from {
    opacity: 0;
    transform: translateY(26rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
