.home-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.hero {
  padding: 34rpx;
  background: radial-gradient(circle at top left, rgba(217, 119, 6, 0.12), transparent 38%),
    linear-gradient(135deg, #ffffff 0%, #eef2ff 100%);
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.08);
  color: #334155;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.15;
  color: #0f172a;
}

.hero-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #475569;
}

.featured,
.feed-head {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.featured-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.premium-pill {
  background: #fff7ed;
  color: #b45309;
}

.featured-card {
  overflow: hidden;
}

.featured-image {
  width: 100%;
  height: 360rpx;
  background: #e2e8f0;
}

.featured-body {
  padding: 28rpx;
}

.featured-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.featured-title {
  margin-top: 16rpx;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #0f172a;
}

.featured-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #475569;
}

.post-card {
  overflow: hidden;
}

.post-image {
  width: 100%;
  height: 280rpx;
  background: #e2e8f0;
}

.post-body {
  padding: 26rpx;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.post-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.post-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  color: #b45309;
  font-size: 20rpx;
  font-weight: 600;
}

.post-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.45;
  color: #0f172a;
}

.post-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #475569;
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  font-size: 22rpx;
  color: #64748b;
}
