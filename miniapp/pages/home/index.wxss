.home-page {
  display: flex;
  flex-direction: column;
}

.club-home {
  background: #ffffff;
  padding: 32rpx 38rpx 128rpx;
}

.club-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: 112rpx;
}

.club-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
  font-family: "STKaiti", "KaiTi", serif;
  box-shadow: inset -8rpx -10rpx 0 rgba(0, 0, 0, 0.16);
}

.club-actions {
  display: flex;
  align-items: center;
  gap: 30rpx;
  padding-top: 8rpx;
}

.club-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #2563eb;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
  box-shadow: 0 0 0 4rpx rgba(15, 23, 42, 0.08);
}

.club-bell {
  position: relative;
  width: 48rpx;
  height: 54rpx;
  border: 6rpx solid #0f172a;
  border-bottom-width: 8rpx;
  border-radius: 26rpx 26rpx 18rpx 18rpx;
  box-sizing: border-box;
}

.club-bell::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -18rpx;
  width: 18rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #0f172a;
  transform: translateX(-50%);
}

.club-hero {
  position: relative;
  padding: 92rpx 8rpx 78rpx;
}

.club-orbit {
  width: 74rpx;
  height: 54rpx;
  margin-bottom: 78rpx;
  border: 14rpx solid #2563eb;
  border-radius: 50%;
  transform: rotate(2deg);
}

.club-title {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #020617;
  font-size: 68rpx;
  font-weight: 500;
  line-height: 1.2;
  letter-spacing: 4rpx;
  font-family: "STKaiti", "KaiTi", "Songti SC", serif;
}

.club-slogan {
  margin-top: 66rpx;
  color: #1f2937;
  font-size: 34rpx;
  line-height: 1.6;
  font-family: "Songti SC", "STSong", serif;
}

.club-entry-grid {
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  margin-top: 26rpx;
}

.club-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  width: 33.333%;
}

.entry-icon-frame {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
}

.entry-image-icon {
  width: 88rpx;
  height: 88rpx;
}

.entry-icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
}

.entry-book {
  border-radius: 10rpx;
  background: linear-gradient(180deg, #050505 0%, #050505 74%, #b8b8b8 74%, #b8b8b8 100%);
}

.entry-book::after {
  content: "";
  position: absolute;
  top: 12rpx;
  right: 14rpx;
  width: 14rpx;
  height: 24rpx;
  border-radius: 3rpx;
  background: #ffffff;
}

.entry-search {
  border-radius: 50%;
  background: #050505;
}

.entry-search::before {
  content: "";
  position: absolute;
  top: 16rpx;
  left: 22rpx;
  width: 28rpx;
  height: 16rpx;
  border-top: 7rpx solid #ffffff;
  border-radius: 50%;
  transform: rotate(18deg);
}

.entry-search::after {
  content: "";
  position: absolute;
  right: -8rpx;
  bottom: -5rpx;
  width: 28rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #a8a8a8;
  transform: rotate(45deg);
}

.entry-camera {
  width: 78rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #050505;
}

.entry-camera::before {
  content: "";
  position: absolute;
  top: -12rpx;
  left: 28rpx;
  width: 32rpx;
  height: 18rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #bcbcbc;
}

.entry-camera::after {
  content: "";
  position: absolute;
  top: 14rpx;
  left: 22rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #ffffff;
}

.entry-smile {
  border-radius: 50%;
  background: #050505;
  box-shadow: 0 13rpx 0 #b5b5b5;
}

.entry-smile::before {
  content: "";
  position: absolute;
  top: 20rpx;
  left: 18rpx;
  width: 7rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 29rpx 0 0 #ffffff;
}

.entry-smile::after {
  content: "";
  position: absolute;
  left: 22rpx;
  bottom: 18rpx;
  width: 30rpx;
  height: 15rpx;
  border-radius: 0 0 30rpx 30rpx;
  background: #ffffff;
}

.entry-box {
  height: 54rpx;
  border-radius: 8rpx 8rpx 12rpx 12rpx;
  background: #050505;
}

.entry-box::before {
  content: "";
  position: absolute;
  top: -20rpx;
  left: 8rpx;
  width: 56rpx;
  height: 22rpx;
  border-radius: 8rpx;
  background: #bcbcbc;
}

.entry-text {
  width: 170rpx;
  white-space: nowrap;
  color: #8b8f98;
  font-size: 25rpx;
  font-weight: 500;
  line-height: 1.1;
  text-align: center;
}

.club-section {
  margin-top: 92rpx;
}

.club-section-title {
  color: #0f172a;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.25;
}

.club-section-subtitle {
  margin-top: 12rpx;
  color: #8b8f98;
  font-size: 24rpx;
}

.club-card-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  row-gap: 28rpx;
  margin-top: 36rpx;
}

.club-card {
  overflow: hidden;
  width: 48.3%;
  border-radius: 36rpx;
  background: #f4f4f4;
}

.club-cover-wrap {
  position: relative;
  overflow: hidden;
  width: 100%;
  min-height: 418rpx;
  border-radius: 36rpx;
  background: #f4f4f4;
}

.club-cover {
  width: 100%;
  height: 100%;
}

.club-cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  height: 100%;
  min-height: 418rpx;
  padding: 40rpx 34rpx 34rpx;
  box-sizing: border-box;
  color: #111827;
  font-family: "STKaiti", "KaiTi", serif;
}

.club-card-title {
  color: #111827;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.22;
  align-self: stretch;
  font-family: "STKaiti", "KaiTi", "Songti SC", serif;
}

.club-card-desc {
  margin-top: 26rpx;
  color: #111827;
  font-size: 20rpx;
  line-height: 1.82;
  align-self: stretch;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 8;
  font-family: "Songti SC", "STSong", serif;
}
