<view class="page-shell home-page club-home">
  <view class="club-header">
    <view class="club-logo">独立</view>
    <view class="club-actions">
      <view class="club-badge">小</view>
      <view class="club-bell"></view>
    </view>
  </view>

  <view class="club-hero">
    <view class="club-orbit"></view>
    <view class="club-title">
      <text>独立工作者</text>
      <text>俱乐部</text>
    </view>
    <view class="club-slogan">独立是人生重要主题之一</view>
  </view>

  <view class="club-entry-grid">
    <view class="club-entry" bindtap="openXhsPage">
      <view class="entry-icon-frame">
        <image class="entry-image-icon" mode="aspectFit" src="/assets/icons/xiaohongshu.png" />
      </view>
      <view class="entry-text">小红书专栏</view>
    </view>
    <view class="club-entry">
      <view class="entry-icon-frame">
        <image class="entry-image-icon" mode="aspectFit" src="/assets/icons/ai.png" />
      </view>
      <view class="entry-text">AI专栏</view>
    </view>
    <view class="club-entry">
      <view class="entry-icon-frame">
        <image class="entry-image-icon" mode="aspectFit" src="/assets/icons/thinking.png" />
      </view>
      <view class="entry-text">独立沉思录</view>
    </view>
  </view>

  <view class="club-section">
    <view class="club-section-title">独立工作者专栏</view>
  </view>

  <view wx:if="{{!hero && loading}}" class="loading-state">正在加载文章...</view>

  <view wx:if="{{!hero && !loading}}" class="empty-state">
    暂时还没有可展示的文章
  </view>

  <view class="club-card-grid">
    <view
      wx:for="{{allPosts}}"
      wx:key="slug"
      class="club-card"
      bindtap="openPost"
      data-slug="{{item.slug}}"
    >
      <view class="club-cover-wrap">
        <view class="club-cover-placeholder">
          <view class="club-card-title">{{item.title}}</view>
          <view class="club-card-desc">{{item.description || '阅读全文，继续打开这个微小但圆满的未来。'}}</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading && hero}}" class="loading-state">正在加载更多...</view>
  <view wx:if="{{!hasMore && hero}}" class="loading-state">已经到底了</view>
</view>
