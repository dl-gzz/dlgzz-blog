<view class="page-shell home-page club-home">
  <view class="club-header">
    <view class="club-logo">高级</view>
    <view class="club-actions">
      <view class="club-badge">小</view>
      <view class="club-bell"></view>
    </view>
  </view>

  <view class="club-hero">
    <view class="club-orbit"></view>
    <view class="club-title">
      <text>高级个体户</text>
      <text>俱乐部</text>
      <text class="club-title-en">SECRET LUMINARY SPACE</text>
    </view>
    <view class="club-slogan">打造一个微小但圆满的未来</view>
  </view>

  <view class="club-entry-grid">
    <view class="club-entry {{xhsOpen ? 'is-active' : ''}}" bindtap="openXhsBook">
      <view class="entry-icon entry-book"></view>
      <view class="entry-text">小红书</view>
    </view>
    <view class="club-entry">
      <view class="entry-icon entry-search"></view>
      <view class="entry-text">百万提案</view>
    </view>
    <view class="club-entry">
      <view class="entry-icon entry-camera"></view>
      <view class="entry-text">图文笔记</view>
    </view>
    <view class="club-entry">
      <view class="entry-icon entry-smile"></view>
      <view class="entry-text">实践手记</view>
    </view>
    <view class="club-entry">
      <view class="entry-icon entry-box"></view>
      <view class="entry-text">装备库</view>
    </view>
  </view>

  <view wx:if="{{xhsOpen}}" class="xhs-shelf {{xhsOpening ? 'is-opening' : 'is-open'}}">
    <view class="xhs-book-stage">
      <view class="xhs-book-shadow"></view>
      <view class="xhs-book">
        <view class="xhs-book-page xhs-book-left">
          <text>小红书</text>
          <text>图文笔记</text>
        </view>
        <view class="xhs-book-spine"></view>
        <view class="xhs-book-page xhs-book-right">
          <text>打开灵感册</text>
          <text>双列浏览</text>
        </view>
      </view>
    </view>

    <view class="xhs-waterfall-head">
      <view>
        <view class="xhs-kicker">XIAOHONGSHU NOTES</view>
        <view class="xhs-title">小红书内容集</view>
      </view>
      <view class="xhs-count">{{xhsCount}} 篇</view>
    </view>

    <view wx:if="{{xhsCount}}" class="xhs-waterfall">
      <view class="xhs-column">
        <view
          wx:for="{{xhsLeftPosts}}"
          wx:key="slug"
          class="xhs-card"
          bindtap="openPost"
          data-slug="{{item.slug}}"
        >
          <image wx:if="{{item.image}}" class="xhs-card-cover" mode="aspectFill" src="{{item.image}}" />
          <view wx:else class="xhs-card-cover xhs-card-cover-placeholder">{{item.title}}</view>
          <view class="xhs-card-body">
            <view class="xhs-card-title">{{item.title}}</view>
            <view class="xhs-card-desc">{{item.description}}</view>
          </view>
        </view>
      </view>

      <view class="xhs-column xhs-column-right">
        <view
          wx:for="{{xhsRightPosts}}"
          wx:key="slug"
          class="xhs-card"
          bindtap="openPost"
          data-slug="{{item.slug}}"
        >
          <image wx:if="{{item.image}}" class="xhs-card-cover" mode="aspectFill" src="{{item.image}}" />
          <view wx:else class="xhs-card-cover xhs-card-cover-placeholder">{{item.title}}</view>
          <view class="xhs-card-body">
            <view class="xhs-card-title">{{item.title}}</view>
            <view class="xhs-card-desc">{{item.description}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="xhs-empty">图片内容加载后，会在这里展开成双瀑布。</view>
  </view>

  <view class="club-section">
    <view class="club-section-title">独立工作者年度专栏·精选</view>
    <view class="club-section-subtitle">线上博客更新后，这里会自动同步最新内容</view>
  </view>

  <view wx:if="{{!hero && loading}}" class="loading-state">正在加载文章...</view>

  <view wx:if="{{!hero && !loading}}" class="empty-state">
    暂时还没有可展示的文章
  </view>

  <view class="club-card-grid">
    <view
      wx:for="{{allPosts}}"
      wx:key="slug"
      class="club-card"
      bindtap="openPost"
      data-slug="{{item.slug}}"
    >
      <view class="club-cover-wrap">
        <image wx:if="{{item.image}}" class="club-cover" mode="aspectFill" src="{{item.image}}" />
        <view wx:else class="club-cover-placeholder">
          <text>{{item.title}}</text>
        </view>
        <view wx:if="{{index < 2 || item.premium}}" class="club-new">New</view>
      </view>
      <view class="club-card-body">
        <view class="club-card-title">{{item.title}}</view>
        <view class="club-card-desc">{{item.description}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading && hero}}" class="loading-state">正在加载更多...</view>
  <view wx:if="{{!hasMore && hero}}" class="loading-state">已经到底了</view>
</view>
