.columns-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  background: #ffffff;
}

.columns-hero {
  padding: 40rpx 36rpx 42rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #2563eb 0%, #0f172a 100%);
  color: #ffffff;
}

.columns-kicker {
  display: inline-flex;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 23rpx;
  font-weight: 700;
}

.columns-title {
  margin-top: 28rpx;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.28;
}

.columns-copy {
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 27rpx;
  line-height: 1.8;
}

.price-line {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.hero-button {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.active-badge {
  display: inline-flex;
  margin-top: 28rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
}

.column-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.column-card {
  display: flex;
  gap: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.column-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  border-radius: 22rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 36rpx;
  font-weight: 800;
  flex: 0 0 auto;
}

.column-body {
  flex: 1;
}

.column-title {
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.column-desc {
  margin-top: 10rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.7;
}

.column-meta {
  margin-top: 16rpx;
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 700;
}

.notice-card {
  padding: 30rpx;
  border-radius: 28rpx;
  background: #f8fafc;
}

.notice-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
}

.notice-text {
  margin-top: 12rpx;
  color: #475569;
  font-size: 25rpx;
  line-height: 1.8;
}
