.membership-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.membership-hero,
.benefit-card,
.purchase-card {
  padding: 32rpx;
}

.membership-hero {
  background: radial-gradient(circle at top right, rgba(217, 119, 6, 0.2), transparent 34%),
    linear-gradient(160deg, #0f172a 0%, #1e293b 100%);
  color: #ffffff;
}

.membership-badge {
  display: inline-flex;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  font-weight: 600;
}

.membership-title {
  margin-top: 24rpx;
  font-size: 52rpx;
  font-weight: 700;
}

.membership-price {
  margin-top: 18rpx;
  font-size: 34rpx;
  color: #fde68a;
  font-weight: 600;
}

.membership-copy {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.8);
}

.benefit-list {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.benefit-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: #d97706;
  flex: 0 0 auto;
}

.benefit-text,
.purchase-text {
  font-size: 27rpx;
  line-height: 1.85;
  color: #334155;
}

.purchase-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.purchase-text {
  margin-top: 16rpx;
}

.purchase-card .button-primary {
  margin-top: 24rpx;
}
