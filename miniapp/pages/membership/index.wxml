<view class="page-shell membership-page">
  <view class="membership-hero card">
    <view class="membership-badge">即将开放</view>
    <view class="membership-title">{{planName}}</view>
    <view class="membership-price">{{priceText}}</view>
    <view class="membership-copy">
      我们正在打磨年度会员内容服务。当前版本先开放博客阅读，会员权益会在后续版本中逐步上线。
    </view>
  </view>

  <view class="benefit-card card">
    <view class="section-title">规划内容</view>
    <view class="section-subtitle">以下能力正在规划中，具体开放时间以小程序后续公告为准</view>

    <view class="benefit-list">
      <view wx:for="{{benefits}}" wx:key="index" class="benefit-item">
        <view class="benefit-dot"></view>
        <view class="benefit-text">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="purchase-card card coming-soon-card">
    <view class="purchase-title">当前状态</view>
    <view class="purchase-text">
      年度会员暂未开放。你可以先阅读公开博客内容，后续内容服务上线后会在这里展示入口。
    </view>
    <button class="button-primary button-disabled" bindtap="handleComingSoon">年度会员即将开放</button>
  </view>
</view>
