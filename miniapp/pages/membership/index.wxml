<view class="page-shell columns-page">
  <view class="columns-hero">
    <view class="columns-kicker">独立工作者会员</view>
    <view class="columns-title">{{membershipConfig.planName}}</view>
    <view class="columns-copy">
      {{membership && membership.active ? '会员已生效，可以阅读完整会员文章。' : '开通后解锁会员文章，并获得会员期内全部组件使用权。'}}
    </view>
    <view class="price-line">{{membershipConfig.priceText}}</view>
    <button
      wx:if="{{!(membership && membership.active)}}"
      class="hero-button"
      loading="{{paying}}"
      bindtap="buyMembership"
    >
      {{paying ? '正在创建订单' : '开通会员'}}
    </button>
    <view wx:else class="active-badge">有效期至 {{membership.periodEnd || '当前周期结束'}}</view>
  </view>

  <view class="column-list">
    <view
      wx:for="{{columns}}"
      wx:key="id"
      class="column-card"
      bindtap="openColumn"
      data-id="{{item.id}}"
    >
      <view class="column-icon">{{item.icon}}</view>
      <view class="column-body">
        <view class="column-title">{{item.title}}</view>
        <view class="column-desc">{{item.description}}</view>
        <view class="column-meta">会员权益</view>
      </view>
    </view>
  </view>

  <view class="notice-card">
    <view class="notice-title">会员包含</view>
    <view wx:for="{{membershipConfig.benefits}}" wx:key="index" class="notice-text">
      {{index + 1}}. {{item}}
    </view>
  </view>
</view>
