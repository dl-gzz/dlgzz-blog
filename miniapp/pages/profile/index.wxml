<view class="page-shell profile-page">
  <view class="profile-hero card">
    <view class="profile-title">当前进度</view>
    <view class="profile-status">{{statusText}}</view>
    <view class="profile-desc">
      当前版本聚焦博客阅读与内容更新，更多内容服务会在后续版本逐步开放。
    </view>
  </view>

  <view class="roadmap-card card">
    <view class="section-title">后续计划</view>
    <view class="section-subtitle">围绕内容阅读继续优化</view>

    <view class="roadmap-list">
      <view wx:for="{{tasks}}" wx:key="index" class="roadmap-item">
        <view class="roadmap-index">{{index + 1}}</view>
        <view class="roadmap-text">{{item}}</view>
      </view>
    </view>
  </view>
</view>
