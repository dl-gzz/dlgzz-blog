.post-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.post-hero {
  overflow: hidden;
}

.post-cover {
  width: 100%;
  height: 360rpx;
  background: #e2e8f0;
}

.post-content {
  padding: 30rpx;
}

.post-topline {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.post-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.premium-pill {
  background: #fff7ed;
  color: #b45309;
}

.post-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #0f172a;
}

.post-description {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #475569;
}

.post-author {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #64748b;
}

.locked-card,
.content-card {
  padding: 30rpx;
}

.locked-card {
  background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
}

.locked-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #9a3412;
}

.locked-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #7c2d12;
}

.locked-card .button-primary {
  margin-top: 24rpx;
}

.paragraph-list {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.paragraph-item {
  font-size: 29rpx;
  line-height: 1.95;
  color: #1e293b;
}
