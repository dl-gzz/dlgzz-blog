.post-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.note-article {
  margin: -32rpx -28rpx 0;
  overflow: hidden;
  border-radius: 0;
  background: #ffffff;
  box-shadow: none;
}

.note-gallery {
  position: relative;
  overflow: hidden;
  background: #ffffff;
}

.note-swiper {
  width: 100%;
  height: 1000rpx;
}

.note-cover {
  display: block;
  width: 100%;
  height: 1000rpx;
  background: #ffffff;
}

.note-count {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.note-eyebrow {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.note-title {
  position: relative;
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.28;
  color: #0f172a;
}

.note-description {
  position: relative;
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.85;
  color: #475569;
}

.note-author-row {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
}

.note-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #0f172a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  flex: 0 0 auto;
}

.note-author {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.note-hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.note-author-row .premium-pill {
  margin-left: auto;
}

.note-content {
  position: relative;
  padding: 36rpx 36rpx 120rpx;
  overflow: hidden;
}

.note-content::before {
  content: "";
  position: absolute;
  top: -120rpx;
  right: -90rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(217, 119, 6, 0.12);
}

.note-paragraph-list {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 30rpx;
}

.note-paragraph-item {
  display: flex;
  gap: 18rpx;
  padding: 8rpx 0;
  border-radius: 0;
  background: transparent;
}

.note-paragraph-index {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #fff7ed;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 700;
  flex: 0 0 auto;
}

.note-paragraph-text {
  flex: 1;
  font-size: 29rpx;
  line-height: 1.9;
  color: #1e293b;
}

.note-locked {
  margin: 0 32rpx 28rpx;
}

.post-hero {
  overflow: hidden;
}

.post-cover {
  width: 100%;
  height: 360rpx;
  background: #e2e8f0;
}

.post-content {
  padding: 30rpx;
}

.post-topline {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.post-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.premium-pill {
  background: #fff7ed;
  color: #b45309;
}

.post-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #0f172a;
}

.post-description {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #475569;
}

.post-author {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #64748b;
}

.locked-card,
.content-card {
  padding: 30rpx;
}

.locked-card {
  background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
}

.locked-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #9a3412;
}

.locked-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #7c2d12;
}

.locked-card .button-primary {
  margin-top: 24rpx;
}

.paragraph-list {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.paragraph-item {
  font-size: 29rpx;
  line-height: 1.95;
  color: #1e293b;
}
