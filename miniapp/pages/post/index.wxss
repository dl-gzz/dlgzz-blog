.post-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  background: #ffffff;
}

.xhs-shell {
  margin: -32rpx -28rpx 0;
  min-height: 100vh;
  background: #ffffff;
}

.xhs-gallery {
  position: relative;
  background: #ffffff;
}

.xhs-swiper {
  width: 100%;
  height: 1000rpx;
}

.xhs-cover {
  display: block;
  width: 100%;
  height: 1000rpx;
  background: #ffffff;
}

.xhs-count {
  position: absolute;
  top: 22rpx;
  right: 24rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.xhs-content {
  padding: 34rpx 40rpx 120rpx;
}

.xhs-title {
  color: #0f172a;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.34;
}

.xhs-description {
  margin-top: 16rpx;
  color: #475569;
  font-size: 27rpx;
  line-height: 1.75;
}

.xhs-author-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
}

.xhs-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #2563eb;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
  flex: 0 0 auto;
}

.xhs-author {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 700;
}

.xhs-date {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 22rpx;
}

.xhs-author-row .premium-pill {
  margin-left: auto;
}

.xhs-locked {
  margin: 28rpx 0 0;
}

.xhs-text-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 32rpx;
}

.xhs-paragraph {
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.95;
}

.article-shell {
  margin: -32rpx -28rpx 0;
  min-height: 100vh;
  background: #ffffff;
}

.article-cover {
  display: block;
  width: 100%;
  height: 420rpx;
  background: #f1f5f9;
}

.article-header {
  padding: 44rpx 40rpx 28rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  color: #94a3b8;
  font-size: 23rpx;
}

.premium-pill {
  background: #eff6ff;
  color: #2563eb;
}

.article-title {
  margin-top: 22rpx;
  color: #0f172a;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.28;
}

.article-description {
  margin-top: 20rpx;
  color: #475569;
  font-size: 29rpx;
  line-height: 1.8;
}

.article-author-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 34rpx;
}

.article-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  flex: 0 0 auto;
}

.article-author {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 700;
}

.article-source {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 22rpx;
}

.locked-card {
  margin: 8rpx 40rpx 26rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: #eff6ff;
}

.locked-title {
  color: #1d4ed8;
  font-size: 32rpx;
  font-weight: 800;
}

.locked-desc {
  margin-top: 14rpx;
  color: #1e40af;
  font-size: 26rpx;
  line-height: 1.75;
}

.locked-card .button-primary {
  margin-top: 24rpx;
}

.article-body {
  padding: 8rpx 40rpx 120rpx;
}

.article-heading {
  color: #0f172a;
  font-weight: 800;
}

.article-heading-1 {
  margin-top: 46rpx;
  margin-bottom: 24rpx;
  font-size: 42rpx;
  line-height: 1.32;
}

.article-heading-2 {
  margin-top: 42rpx;
  margin-bottom: 20rpx;
  font-size: 36rpx;
  line-height: 1.36;
}

.article-heading-3 {
  margin-top: 34rpx;
  margin-bottom: 16rpx;
  font-size: 31rpx;
  line-height: 1.42;
}

.article-paragraph {
  margin-top: 24rpx;
  color: #1e293b;
  font-size: 31rpx;
  line-height: 2;
}

.article-quote {
  margin-top: 28rpx;
  padding: 22rpx 26rpx;
  border-left: 8rpx solid #2563eb;
  border-radius: 0 18rpx 18rpx 0;
  background: #f8fafc;
  color: #334155;
  font-size: 29rpx;
  line-height: 1.9;
}

.article-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.article-list-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  color: #1e293b;
  font-size: 30rpx;
  line-height: 1.85;
}

.article-list-marker {
  min-width: 34rpx;
  color: #2563eb;
  font-weight: 800;
  text-align: right;
}

.article-list-text {
  flex: 1;
}

.article-inline-image {
  display: block;
  width: 100%;
  margin-top: 30rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
}

.article-code {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #0f172a;
  color: #e2e8f0;
  font-family: Menlo, Monaco, Consolas, monospace;
  font-size: 23rpx;
  line-height: 1.7;
  white-space: pre;
}

.article-divider {
  width: 96rpx;
  height: 2rpx;
  margin: 42rpx auto 18rpx;
  background: #cbd5e1;
}
