<view class="page-shell post-page">
  <view wx:if="{{loading}}" class="loading-state">正在加载文章...</view>

  <block wx:if="{{detail}}">
    <view class="post-hero card">
      <image wx:if="{{detail.image}}" class="post-cover" mode="aspectFill" src="{{detail.image}}" />
      <view class="post-content">
        <view class="post-topline">
          <text class="post-date">{{detail.date}}</text>
          <text wx:if="{{detail.premium}}" class="pill premium-pill">会员文章</text>
        </view>
        <view class="post-title">{{detail.title}}</view>
        <view class="post-description">{{detail.description}}</view>
        <view class="post-author">{{detail.authorName || '独立工作者'}}</view>
      </view>
    </view>

    <view wx:if="{{detail.locked}}" class="locked-card card">
      <view class="locked-title">当前是预览模式</view>
      <view class="locked-desc">
        这篇文章已经标记为会员内容。现在先展示预览段落，后面接上登录与支付后就能直接按会员态解锁全文。
      </view>
      <button class="button-primary" bindtap="openMembership">查看年度会员</button>
    </view>

    <view class="content-card card">
      <view class="section-title">正文</view>
      <view class="section-subtitle">
        {{detail.locked ? '以下为预览内容' : '当前内容直接来自博客文章源'}}
      </view>

      <view class="paragraph-list">
        <view wx:for="{{detail.contentParagraphs}}" wx:key="index" class="paragraph-item">
          {{item}}
        </view>
      </view>
    </view>
  </block>
</view>
