page {
  min-height: 100%;
  background: #f5f7fb;
  color: #0f172a;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 120rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(15, 23, 42, 0.08);
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.button-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.button-primary::after {
  border: none;
}

.empty-state,
.loading-state {
  padding: 60rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #64748b;
}
